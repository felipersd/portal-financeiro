generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id          String   @id @default(uuid())
  description String
  amount      Float
  type        String   // 'income' | 'expense'
  category    String
  date        DateTime
  isShared    Boolean
  isFixed     Boolean  @default(false)
  payer       String   // 'me' | 'spouse'
  createdAt   DateTime @default(now())
  recurrenceId String?
  splitDetails Json?
  
  userId      String   // Logical reference to IdentityService User
}

model Category {
  id   String @id @default(uuid())
  name String
  type String // 'income' | 'expense'
  
  userId String // Logical reference to IdentityService User
}

model GroupMember {
  id        String   @id @default(uuid())
  name      String
  surname   String?
  email     String?
  category  String   // 'Filho(a)', 'Cônjuge', 'Pai(a)', etc.
  userId    String
  createdAt DateTime @default(now())
}

model BudgetRule {
  id         String   @id @default(uuid())
  userId     String   // Logical reference to User
  month      String   // Format: YYYY-MM
  divisions  Json     @default("[]") // Array of custom divisions
  mapping    Json     @default("{}") // e.g. { "Mercado": "divisionId_1" }
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, month])
}
